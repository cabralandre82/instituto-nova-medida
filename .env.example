# Template de variáveis de ambiente
# Copie para .env.local e preencha com seus valores reais
# NUNCA commite .env.local no git

# ============================================
# Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ============================================
# Ambiente
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flag PR-020 · audit [1.1]:
# Controla se as rotas legadas /checkout/[plano] e /agendar/[plano]
# aceitam compra direta (sem consulta médica prévia).
# Default em produção: false (fluxo canônico D-044).
# Default em dev/test: true.
# Só setar em produção se precisar enviar link manual excepcional.
# LEGACY_PURCHASE_ENABLED=false

# ============================================
# Pagamento (Sprint 3)
# ============================================
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# ============================================
# Receita digital (Sprint 4)
# ============================================
MEMED_API_KEY=
MEMED_API_SECRET=
MEMED_ENV=sandbox

# ============================================
# Vídeo teleconsulta (Sprint 4)
# ============================================
DAILY_API_KEY=
DAILY_DOMAIN=
DAILY_WEBHOOK_SECRET=
# VIDEO_PROVIDER=daily   # default; 'jitsi' quando migrarmos (D-021)

# ============================================
# WhatsApp Cloud API / Meta (Sprint 2)
# ============================================
META_APP_ID=
META_APP_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Número (E.164, ex: +5511987654321) que recebe o rollup diário da
# operação. Usado pelo cron /api/internal/cron/admin-digest. Se vazio,
# o cron registra e pula sem erro. D-045 · 3.D.
ADMIN_DIGEST_PHONE=

# ============================================
# Analytics (Sprint 5)
# ============================================
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
META_CAPI_ACCESS_TOKEN=
