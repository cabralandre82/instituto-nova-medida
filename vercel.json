{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "functions": {
    "src/app/api/lead/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/wa/webhook/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/debug/wa-env/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/internal/cron/expire-reservations/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/cron/expire-reservations",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/daily/webhook",
      "headers": [
        { "key": "Vary", "value": "Accept-Encoding" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/asaas/webhook",
      "headers": [
        { "key": "Vary", "value": "Accept-Encoding" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
